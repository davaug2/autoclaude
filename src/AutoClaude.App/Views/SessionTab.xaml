<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="AutoClaude.App.Views.SessionTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:AutoClaude.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:AutoClaude.App.Controls"
    xmlns:local="using:AutoClaude.App.Views"
    xmlns:vm="using:AutoClaude.App.ViewModels"
    x:DataType="local:SessionTab"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InvertBoolToVis" Invert="True" />
    </UserControl.Resources>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: Status + Interrupt -->
        <Border
            Grid.Row="0"
            Padding="16,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <ProgressRing
                        Width="16"
                        Height="16"
                        IsActive="{x:Bind ViewModel.IsExecuting, Mode=OneWay}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.StatusLine, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="12">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.ElapsedText, Mode=OneWay}" />
                    <Button
                        Padding="6,4"
                        Command="{x:Bind ViewModel.ToggleCliOutputCommand, Mode=OneTime}"
                        FontSize="12"
                        ToolTipService.ToolTip="Mostrar/ocultar saída do processo">
                        <FontIcon FontSize="12" Glyph="&#xE756;" />
                    </Button>
                    <Button
                        Padding="6,4"
                        Command="{x:Bind ViewModel.ToggleDetailsCommand, Mode=OneTime}"
                        FontSize="12"
                        ToolTipService.ToolTip="Detalhes da sessao">
                        <FontIcon FontSize="12" Glyph="&#xE8A7;" />
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.InterruptCommand, Mode=OneTime}"
                        Content="Interromper"
                        Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Modo Execução -->
        <Grid
            x:Name="ExecutionGrid"
            Grid.Row="1"
            Grid.RowSpan="3"
            Visibility="{x:Bind ViewModel.IsDetailsVisible, Mode=OneWay, Converter={StaticResource InvertBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="200" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Log area (top) -->
            <ScrollViewer
                x:Name="LogScroller"
                Grid.Row="0"
                Padding="16,8"
                VerticalScrollBarVisibility="Auto">
                <TextBlock
                    FontFamily="Cascadia Mono, Consolas"
                    FontSize="12"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.LogText, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </ScrollViewer>

            <!-- Resize splitter -->
            <controls:SplitterBar
                x:Name="Splitter"
                Grid.Row="1"
                Background="Transparent"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,1"
                PointerPressed="OnSplitterPointerPressed"
                PointerMoved="OnSplitterPointerMoved"
                PointerReleased="OnSplitterPointerReleased" />

            <!-- CLI Input/Output (bottom, resizable) -->
            <Border
                Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Pivot>
                    <PivotItem Header="Output">
                        <ScrollViewer
                            x:Name="CliOutputScroller"
                            Padding="8,4"
                            VerticalScrollBarVisibility="Auto">
                            <TextBlock
                                FontFamily="Cascadia Mono, Consolas"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.CliOutput, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </PivotItem>
                    <PivotItem Header="Input">
                        <ScrollViewer
                            Padding="8,4"
                            VerticalScrollBarVisibility="Auto">
                            <TextBlock
                                FontFamily="Cascadia Mono, Consolas"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.CliInput, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </PivotItem>
                </Pivot>
            </Border>

            <!-- Input area -->
            <Border
                Grid.Row="3"
                Padding="16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="InputBox"
                        AcceptsReturn="True"
                        IsEnabled="{x:Bind ViewModel.IsInputVisible, Mode=OneWay}"
                        KeyDown="OnInputKeyDown"
                        MaxHeight="150"
                        MinHeight="36"
                        PlaceholderText="{x:Bind ViewModel.InputPlaceholder, Mode=OneWay}"
                        Text="{x:Bind ViewModel.UserInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.SendInputCommand, Mode=OneTime}"
                        Content="Enviar"
                        Style="{StaticResource AccentButtonStyle}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Modo Detalhes -->
        <ContentPresenter
            x:Name="DetailsContainer"
            Grid.Row="1"
            Grid.RowSpan="3"
            Visibility="{x:Bind ViewModel.IsDetailsVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
