<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="AutoClaude.App.Views.SessionTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:AutoClaude.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:sessionEvents="using:AutoClaude.App.Views.SessionEvents"
    xmlns:vm="using:AutoClaude.App.ViewModels.SessionEvents"
    xmlns:local="using:AutoClaude.App.Views"
    x:DataType="local:SessionTab"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InvertBoolToVis" Invert="True" />
        <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVis" />
        <converters:OutcomeToBrushConverter x:Key="OutcomeToBrush" />
        <converters:OutcomeToGlyphConverter x:Key="OutcomeToGlyph" />
        <converters:InfoSeverityToInfoBarSeverityConverter x:Key="InfoSeverityToInfoBar" />

        <!-- Phase started card -->
        <DataTemplate x:Key="PhaseStartedTemplate" x:DataType="vm:PhaseStartedEventViewModel">
            <Border Margin="0,8,0,4"
                    Padding="14,10"
                    Background="{ThemeResource AccentFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="4,0,0,0"
                    CornerRadius="6">
                <StackPanel Spacing="4">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  Glyph="&#xE909;" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}">
                            <Run Text="Fase " />
                            <Run Text="{x:Bind Ordinal}" />
                            <Run Text=" — " />
                            <Run Text="{x:Bind Name}" />
                        </TextBlock>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Opacity="0.6"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="{x:Bind TimestampText}" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Padding="6,2"
                                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                CornerRadius="10">
                            <TextBlock FontSize="11"
                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                       Text="{x:Bind PhaseTypeLabel}" />
                        </Border>
                        <Border Padding="6,2"
                                Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                CornerRadius="10">
                            <TextBlock FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind RepeatModeLabel}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Opacity="0.85"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{x:Bind Description}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind Description, Converter={StaticResource NullOrEmptyToVis}}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Phase completed card -->
        <DataTemplate x:Key="PhaseCompletedTemplate" x:DataType="vm:PhaseCompletedEventViewModel">
            <Border Margin="0,4"
                    Padding="12,8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="6">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon FontSize="14"
                              Glyph="&#xE930;"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                              Visibility="{x:Bind Success, Converter={StaticResource BoolToVis}}" />
                    <FontIcon FontSize="14"
                              Glyph="&#xE783;"
                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                              Visibility="{x:Bind Success, Converter={StaticResource InvertBoolToVis}}" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="{x:Bind Headline}" />
                        <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="{x:Bind ErrorMessage}"
                                   TextWrapping="Wrap"
                                   Visibility="{x:Bind ErrorMessage, Converter={StaticResource NullOrEmptyToVis}}" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{x:Bind TimestampText}" />
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Task started card -->
        <DataTemplate x:Key="TaskStartedTemplate" x:DataType="vm:TaskStartedEventViewModel">
            <Border Margin="16,4,0,4"
                    Padding="12,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SystemAccentColorLight2}"
                    BorderThickness="3,0,0,0"
                    CornerRadius="4">
                <StackPanel Spacing="2">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontSize="14" Glyph="&#xE762;" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}">
                            <Run Text="Tarefa " />
                            <Run Text="{x:Bind Ordinal}" />
                            <Run Text=": " />
                            <Run Text="{x:Bind Title}" />
                        </TextBlock>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Opacity="0.6"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="{x:Bind TimestampText}" />
                    </Grid>
                    <TextBlock Opacity="0.75"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{x:Bind Description}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind Description, Converter={StaticResource NullOrEmptyToVis}}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Subtask started card -->
        <DataTemplate x:Key="SubtaskStartedTemplate" x:DataType="vm:SubtaskStartedEventViewModel">
            <Border Margin="32,2,0,2"
                    Padding="10,6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="2,0,0,0"
                    CornerRadius="4">
                <StackPanel Spacing="2">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon FontSize="12" Glyph="&#xE82D;" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Style="{ThemeResource BodyTextBlockStyle}">
                            <Run Text="Subtarefa " />
                            <Run Text="{x:Bind Ordinal}" />
                            <Run Text=": " />
                            <Run Text="{x:Bind Title}" />
                        </TextBlock>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Opacity="0.6"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="{x:Bind TimestampText}" />
                    </Grid>
                    <TextBlock FontFamily="Cascadia Mono, Consolas"
                               FontSize="11"
                               Opacity="0.7"
                               Text="{x:Bind WorkingDirectory}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{x:Bind WorkingDirectory, Converter={StaticResource NullOrEmptyToVis}}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Execution card with expandable CLI output -->
        <DataTemplate x:Key="ExecutionTemplate" x:DataType="vm:ExecutionEventViewModel">
            <Border Margin="0,6"
                    Padding="12,10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{x:Bind Outcome, Converter={StaticResource OutcomeToBrush}, Mode=OneWay}"
                    BorderThickness="0,0,0,2"
                    CornerRadius="6">
                <StackPanel Spacing="6">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon VerticalAlignment="Center"
                                  FontSize="16"
                                  Foreground="{x:Bind Outcome, Converter={StaticResource OutcomeToBrush}, Mode=OneWay}"
                                  Glyph="{x:Bind Outcome, Converter={StaticResource OutcomeToGlyph}, Mode=OneWay}" />
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Execução" />
                            <Border Padding="6,1"
                                    Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                    CornerRadius="8"
                                    Visibility="{x:Bind IsRetry, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="{x:Bind AttemptLabel}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   FontFamily="Cascadia Mono, Consolas"
                                   Opacity="0.8"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="{x:Bind DurationText, Mode=OneWay}" />
                        <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center"
                                   Opacity="0.6"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Text="{x:Bind TimestampText}" />
                    </Grid>
                    <TextBlock MaxLines="3"
                               Opacity="0.85"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{x:Bind PromptPreview}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind PromptPreview, Converter={StaticResource NullOrEmptyToVis}}" />
                    <controls:InfoBar IsClosable="False"
                                      IsOpen="True"
                                      Message="{x:Bind ErrorMessage, Mode=OneWay}"
                                      Severity="Error"
                                      Visibility="{x:Bind ErrorMessage, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay}" />
                    <Expander HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              IsExpanded="{x:Bind IsCliOutputExpanded, Mode=TwoWay}"
                              Visibility="{x:Bind CliOutputBuffer, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="12" Glyph="&#xE756;" />
                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="Saída do CLI" />
                            </StackPanel>
                        </Expander.Header>
                        <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                            <TextBlock FontFamily="Cascadia Mono, Consolas"
                                       FontSize="12"
                                       IsTextSelectionEnabled="True"
                                       Text="{x:Bind CliOutputBuffer, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Expander>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Retry card -->
        <DataTemplate x:Key="RetryTemplate" x:DataType="vm:RetryEventViewModel">
            <controls:InfoBar Margin="0,4"
                              IsClosable="False"
                              IsOpen="True"
                              Message="Aguardando para tentar novamente..."
                              Severity="Warning"
                              Title="Nova tentativa">
                <StackPanel Margin="0,4,0,8" Spacing="4">
                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                        <Run Text="Tentativa " />
                        <Run Text="{x:Bind Attempt}" />
                        <Run Text=" de " />
                        <Run Text="{x:Bind MaxAttempts}" />
                        <Run Text=" em " />
                        <Run Text="{x:Bind DelaySeconds}" />
                        <Run Text="s" />
                    </TextBlock>
                    <TextBlock Opacity="0.8"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{x:Bind Reason}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind Reason, Converter={StaticResource NullOrEmptyToVis}}" />
                </StackPanel>
            </controls:InfoBar>
        </DataTemplate>

        <!-- Interpreting intent card -->
        <DataTemplate x:Key="InterpretingIntentTemplate" x:DataType="vm:InterpretingIntentEventViewModel">
            <Border Margin="0,4"
                    Padding="12,8"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="6">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressRing Width="16"
                                  Height="16"
                                  IsActive="{x:Bind IsInProgress, Mode=OneWay}"
                                  Visibility="{x:Bind IsCompleted, Converter={StaticResource InvertBoolToVis}, Mode=OneWay}" />
                    <FontIcon Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                              Glyph="&#xE930;"
                              Visibility="{x:Bind IsCompleted, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="Interpretando intenção do usuário..."
                               Visibility="{x:Bind IsCompleted, Converter={StaticResource InvertBoolToVis}, Mode=OneWay}" />
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="Intenção interpretada."
                               Visibility="{x:Bind IsCompleted, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{x:Bind TimestampText}" />
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Info / error / warning card -->
        <DataTemplate x:Key="InfoTemplate" x:DataType="vm:InfoEventViewModel">
            <controls:InfoBar Margin="0,2"
                              IsClosable="False"
                              IsOpen="True"
                              Message="{x:Bind Message}"
                              Severity="{x:Bind Severity, Converter={StaticResource InfoSeverityToInfoBar}}" />
        </DataTemplate>

        <!-- User question card (free-form text) -->
        <DataTemplate x:Key="UserQuestionTemplate" x:DataType="vm:UserQuestionEventViewModel">
            <Border Margin="0,6"
                    Padding="12,10"
                    Background="{ThemeResource AccentFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="0,0,0,2"
                    CornerRadius="6">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE8BD;" />
                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Pergunta" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind Prompt}" TextWrapping="Wrap" />
                    <Grid ColumnSpacing="8"
                          Visibility="{x:Bind IsAnswered, Converter={StaticResource InvertBoolToVis}, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox MinHeight="36"
                                 AcceptsReturn="True"
                                 PlaceholderText="Sua resposta..."
                                 Text="{x:Bind Answer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" />
                        <Button Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind SubmitCommand}"
                                Content="Enviar"
                                Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <Border Padding="8,6"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="4"
                            Visibility="{x:Bind IsAnswered, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                        <TextBlock Opacity="0.85" Text="{x:Bind Answer, Mode=OneWay}" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- User decision card (multiple choice buttons) -->
        <DataTemplate x:Key="DecisionOptionButtonTemplate" x:DataType="vm:DecisionOption">
            <Button MinWidth="100"
                    Margin="0,0,8,8"
                    Command="{x:Bind SelectCommand}"
                    Content="{x:Bind Label}" />
        </DataTemplate>

        <DataTemplate x:Key="UserDecisionTemplate" x:DataType="vm:UserDecisionEventViewModel">
            <Border Margin="0,6"
                    Padding="12,10"
                    Background="{ThemeResource AccentFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="0,0,0,2"
                    CornerRadius="6">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE7BA;" />
                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Decisão necessária" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind Prompt}" TextWrapping="Wrap" />
                    <ItemsRepeater ItemTemplate="{StaticResource DecisionOptionButtonTemplate}"
                                   ItemsSource="{x:Bind Options}">
                        <ItemsRepeater.Layout>
                            <controls:StackLayout Orientation="Horizontal" Spacing="0" />
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                    <Border Padding="8,6"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="4"
                            Visibility="{x:Bind IsAnswered, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                            <Run Text="Escolha: " />
                            <Run FontWeight="SemiBold" Text="{x:Bind ChosenLabel, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- User confirmation card (Confirm/Modify/GoBack/Reject) -->
        <DataTemplate x:Key="UserConfirmationTemplate" x:DataType="vm:UserConfirmationEventViewModel">
            <Border Margin="0,6"
                    Padding="12,10"
                    Background="{ThemeResource AccentFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="0,0,0,2"
                    CornerRadius="6">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE9CE;" />
                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind Title}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind Details}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ConfirmCommand}"
                                Content="Confirmar"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button Command="{x:Bind ModifyCommand}" Content="Modificar" />
                        <Button Command="{x:Bind GoBackCommand}" Content="Voltar fase anterior" />
                        <Button Command="{x:Bind RejectCommand}" Content="Rejeitar" />
                    </StackPanel>
                    <Border Padding="8,6"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="4"
                            Visibility="{x:Bind IsAnswered, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                            <Run Text="Escolha: " />
                            <Run FontWeight="SemiBold" Text="{x:Bind ChosenLabel, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Template selector -->
        <sessionEvents:SessionEventTemplateSelector x:Key="SessionEventSelector"
                                                    PhaseStartedTemplate="{StaticResource PhaseStartedTemplate}"
                                                    PhaseCompletedTemplate="{StaticResource PhaseCompletedTemplate}"
                                                    TaskStartedTemplate="{StaticResource TaskStartedTemplate}"
                                                    SubtaskStartedTemplate="{StaticResource SubtaskStartedTemplate}"
                                                    ExecutionTemplate="{StaticResource ExecutionTemplate}"
                                                    RetryTemplate="{StaticResource RetryTemplate}"
                                                    InterpretingIntentTemplate="{StaticResource InterpretingIntentTemplate}"
                                                    InfoTemplate="{StaticResource InfoTemplate}"
                                                    UserQuestionTemplate="{StaticResource UserQuestionTemplate}"
                                                    UserDecisionTemplate="{StaticResource UserDecisionTemplate}"
                                                    UserConfirmationTemplate="{StaticResource UserConfirmationTemplate}" />
    </UserControl.Resources>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: breadcrumb + timer + controls -->
        <Border Grid.Row="0"
                Padding="16,10"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ProgressRing Width="18"
                              Height="18"
                              IsActive="{x:Bind ViewModel.IsExecuting, Mode=OneWay}" />

                <!-- Breadcrumb: Phase > Task > Subtask -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Opacity="0.85"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="{x:Bind ViewModel.StatusLine, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{x:Bind ViewModel.CurrentPhaseName, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay, ConverterParameter=Invert}" />

                    <TextBlock VerticalAlignment="Center"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Text="{x:Bind ViewModel.CurrentPhaseName, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.CurrentPhaseName, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay}" />

                    <FontIcon VerticalAlignment="Center"
                              FontSize="10"
                              Glyph="&#xE76C;"
                              Opacity="0.5"
                              Visibility="{x:Bind ViewModel.CurrentTaskTitle, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay}" />
                    <TextBlock VerticalAlignment="Center"
                               Opacity="0.85"
                               Text="{x:Bind ViewModel.CurrentTaskTitle, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.CurrentTaskTitle, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay}" />

                    <FontIcon VerticalAlignment="Center"
                              FontSize="10"
                              Glyph="&#xE76C;"
                              Opacity="0.5"
                              Visibility="{x:Bind ViewModel.CurrentSubtaskTitle, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay}" />
                    <TextBlock VerticalAlignment="Center"
                               Opacity="0.7"
                               Text="{x:Bind ViewModel.CurrentSubtaskTitle, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.CurrentSubtaskTitle, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay}" />
                </StackPanel>

                <!-- Elapsed timer badge -->
                <Border Grid.Column="2"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                        CornerRadius="10"
                        Visibility="{x:Bind ViewModel.ElapsedText, Converter={StaticResource NullOrEmptyToVis}, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon FontSize="11" Glyph="&#xE916;" />
                        <TextBlock FontFamily="Cascadia Mono, Consolas"
                                   FontSize="12"
                                   Text="{x:Bind ViewModel.ElapsedText, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Button Grid.Column="3"
                        Padding="8,6"
                        Command="{x:Bind ViewModel.ToggleDetailsCommand, Mode=OneTime}"
                        ToolTipService.ToolTip="Detalhes da sessão">
                    <FontIcon FontSize="14" Glyph="&#xE8A7;" />
                </Button>

                <Button Grid.Column="4"
                        Command="{x:Bind ViewModel.InterruptCommand, Mode=OneTime}"
                        Content="Interromper"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <!-- Execution timeline -->
        <ScrollViewer x:Name="EventsScroller"
                      Grid.Row="1"
                      Padding="16,12"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{x:Bind ViewModel.IsDetailsVisible, Mode=OneWay, Converter={StaticResource InvertBoolToVis}}">
            <ItemsRepeater ItemTemplate="{StaticResource SessionEventSelector}" ItemsSource="{x:Bind ViewModel.Events, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <controls:StackLayout Orientation="Vertical" Spacing="0" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Details panel -->
        <ContentPresenter x:Name="DetailsContainer"
                          Grid.Row="1"
                          Visibility="{x:Bind ViewModel.IsDetailsVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
