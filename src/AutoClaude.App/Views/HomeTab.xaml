<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="AutoClaude.App.Views.HomeTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:AutoClaude.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:AutoClaude.App.Views"
    xmlns:vm="using:AutoClaude.App.ViewModels"
    x:DataType="local:HomeTab"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrush" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InvertBoolToVis" Invert="True" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" Margin="24,16" Spacing="16">

            <!-- New Session Form -->
            <TextBlock
                FontSize="20"
                FontWeight="SemiBold"
                Text="Nova sessao" />

            <TextBox
                Header="Objetivo"
                PlaceholderText="Descreva o objetivo da sessao"
                Text="{x:Bind ViewModel.Objective, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    Header="Caminho do projeto"
                    PlaceholderText="Vazio = pasta do usuario"
                    Text="{x:Bind ViewModel.TargetPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ComboBox
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Header="Modelo"
                    ItemsSource="{x:Bind ViewModel.WorkModels}"
                    SelectedItem="{x:Bind ViewModel.SelectedWorkModel, Mode=TwoWay}" />
            </Grid>

            <Button
                Command="{x:Bind ViewModel.NewSessionCommand}"
                Content="Iniciar nova sessao"
                Style="{StaticResource AccentButtonStyle}" />

            <!-- Divider -->
            <Border
                Height="1"
                Margin="0,8"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Sessions Header -->
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Sessoes" />
                <Button
                    HorizontalAlignment="Right"
                    Command="{x:Bind ViewModel.RefreshSessionsCommand}"
                    ToolTipService.ToolTip="Atualizar lista">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                </Button>
            </Grid>

            <!-- Empty state -->
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Nenhuma sessao encontrada."
                Visibility="{x:Bind ViewModel.HasNoSessions, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

            <!-- Sessions List -->
            <ListView
                ItemsSource="{x:Bind ViewModel.Sessions}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SessionListItem">
                        <Grid Padding="4,10" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Status indicator -->
                            <Ellipse
                                Grid.Column="0"
                                Width="10"
                                Height="10"
                                VerticalAlignment="Center"
                                Fill="{x:Bind Status, Converter={StaticResource StatusToBrush}}" />

                            <!-- Session info -->
                            <StackPanel Grid.Column="1" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                    <TextBlock
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{x:Bind StatusText}" />
                                </StackPanel>
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ObjectivePreview}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="4">
                                <Button
                                    VerticalAlignment="Center"
                                    Click="OnOpenSessionClick"
                                    Content="Abrir"
                                    FontSize="12"
                                    Tag="{x:Bind}" />
                                <Button
                                    VerticalAlignment="Center"
                                    Click="OnDeleteSessionClick"
                                    Content="Excluir"
                                    FontSize="12"
                                    Tag="{x:Bind}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</UserControl>
