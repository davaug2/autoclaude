<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="AutoClaude.App.Views.SessionDetailsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:AutoClaude.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AutoClaude.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AutoClaude.App.ViewModels"
    x:DataType="local:SessionDetailsPanel"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="20">

            <!-- Objetivo (editável) -->
            <StackPanel Spacing="6">
                <Grid>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Objetivo" />
                    <Button
                        HorizontalAlignment="Right"
                        Command="{x:Bind ViewModel.SaveObjectiveCommand}"
                        Content="Salvar"
                        FontSize="12" />
                </Grid>
                <TextBox
                    AcceptsReturn="True"
                    MaxHeight="200"
                    MinHeight="60"
                    Text="{x:Bind ViewModel.Objective, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!-- CLI Session ID -->
            <StackPanel Spacing="6">
                <Grid>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Claude Session ID" />
                    <Button
                        HorizontalAlignment="Right"
                        Command="{x:Bind ViewModel.SaveCliSessionIdCommand}"
                        Content="Salvar"
                        FontSize="12" />
                </Grid>
                <TextBox
                    FontFamily="Cascadia Mono, Consolas"
                    FontSize="12"
                    PlaceholderText="Vazio = nova sessao a cada execucao"
                    Text="{x:Bind ViewModel.CliSessionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- Diretórios permitidos -->
            <StackPanel Spacing="6">
                <Grid>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Diretorios permitidos" />
                    <Button
                        HorizontalAlignment="Right"
                        Click="OnAddDirectoryClick"
                        Padding="6,4"
                        ToolTipService.ToolTip="Adicionar diretorio">
                        <FontIcon FontSize="12" Glyph="&#xE710;" />
                    </Button>
                </Grid>
                <Grid
                    ColumnSpacing="8"
                    Visibility="{x:Bind ViewModel.IsAddingDirectory, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        PlaceholderText="C:\caminho\do\projeto"
                        Text="{x:Bind ViewModel.NewDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Grid.Column="1"
                        Command="{x:Bind ViewModel.ConfirmAddDirectoryCommand}"
                        Content="Adicionar"
                        Style="{StaticResource AccentButtonStyle}" />
                </Grid>
                <ListView ItemsSource="{x:Bind ViewModel.AllowedDirectories}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid Padding="4,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE8B7;" />
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontFamily="Cascadia Mono, Consolas"
                                    FontSize="12"
                                    IsTextSelectionEnabled="True"
                                    Text="{x:Bind}" />
                                <Button
                                    Grid.Column="2"
                                    Click="OnRemoveDirectoryClick"
                                    Padding="4"
                                    Tag="{x:Bind}"
                                    ToolTipService.ToolTip="Remover">
                                    <FontIcon FontSize="10" Glyph="&#xE711;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- Memórias Persistentes (editáveis) -->
            <Expander
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                IsExpanded="True">
                <Expander.Header>
                    <Grid>
                        <TextBlock VerticalAlignment="Center" Text="Memorias persistentes" />
                        <StackPanel
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Button
                                Click="OnAddPersistentMemoryClick"
                                Padding="4"
                                ToolTipService.ToolTip="Adicionar">
                                <FontIcon FontSize="10" Glyph="&#xE710;" />
                            </Button>
                            <Button
                                Command="{x:Bind ViewModel.SaveMemoriesCommand}"
                                Content="Salvar"
                                FontSize="11"
                                Padding="8,4" />
                        </StackPanel>
                    </Grid>
                </Expander.Header>
                <ListView ItemsSource="{x:Bind ViewModel.PersistentMemories}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MemoryEntryItem">
                            <Grid Padding="4,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    FontSize="12"
                                    PlaceholderText="Pergunta"
                                    Text="{x:Bind Question, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox
                                    Grid.Column="1"
                                    FontSize="12"
                                    PlaceholderText="Resposta"
                                    Text="{x:Bind Answer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    Grid.Column="2"
                                    Click="OnRemovePersistentMemoryClick"
                                    Padding="4"
                                    Tag="{x:Bind}"
                                    ToolTipService.ToolTip="Remover">
                                    <FontIcon FontSize="10" Glyph="&#xE711;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

            <!-- Memórias Temporárias (editáveis) -->
            <Expander
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <Grid>
                        <TextBlock VerticalAlignment="Center" Text="Memorias temporarias" />
                        <StackPanel
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Button
                                Click="OnAddTemporaryMemoryClick"
                                Padding="4"
                                ToolTipService.ToolTip="Adicionar">
                                <FontIcon FontSize="10" Glyph="&#xE710;" />
                            </Button>
                            <Button
                                Command="{x:Bind ViewModel.SaveMemoriesCommand}"
                                Content="Salvar"
                                FontSize="11"
                                Padding="8,4" />
                        </StackPanel>
                    </Grid>
                </Expander.Header>
                <ListView ItemsSource="{x:Bind ViewModel.TemporaryMemories}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MemoryEntryItem">
                            <Grid Padding="4,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    FontSize="12"
                                    PlaceholderText="Pergunta"
                                    Text="{x:Bind Question, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox
                                    Grid.Column="1"
                                    FontSize="12"
                                    PlaceholderText="Resposta"
                                    Text="{x:Bind Answer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    Grid.Column="2"
                                    Click="OnRemoveTemporaryMemoryClick"
                                    Padding="4"
                                    Tag="{x:Bind}"
                                    ToolTipService.ToolTip="Remover">
                                    <FontIcon FontSize="10" Glyph="&#xE711;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

            <!-- Tasks e Subtasks -->
            <Expander
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Header="Tasks e Subtasks"
                IsExpanded="True">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Tasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskTreeItem">
                            <Expander
                                Margin="0,2"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                IsExpanded="True">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind StatusIcon}" />
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind StatusText}" />
                                    </StackPanel>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{x:Bind Subtasks}" Padding="20,4,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SubtaskTreeItem">
                                            <StackPanel Padding="0,3" Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind StatusIcon}" />
                                                <TextBlock Text="{x:Bind Title}" />
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind StatusText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <!-- Execuções -->
            <Expander
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Header="Execucoes">
                <ListView ItemsSource="{x:Bind ViewModel.Executions}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ExecutionItem">
                            <Border
                                Margin="0,4"
                                Padding="12,10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <StackPanel Spacing="8">
                                    <!-- Header: Resultado + Timestamps -->
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Outcome}" />
                                        <TextBlock
                                            FontFamily="Cascadia Mono, Consolas"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind StartedAt}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="->" />
                                        <TextBlock
                                            FontFamily="Cascadia Mono, Consolas"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind CompletedAt}" />
                                    </StackPanel>
                                    <!-- Input -->
                                    <TextBox
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Header="Input"
                                        IsReadOnly="True"
                                        MaxHeight="120"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        Text="{x:Bind Input}" />
                                    <!-- Output -->
                                    <TextBox
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Header="Output"
                                        IsReadOnly="True"
                                        MaxHeight="120"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        Text="{x:Bind Output}" />
                                    <!-- Erro (só se houver) -->
                                    <TextBox
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Foreground="Red"
                                        Header="Erro"
                                        IsReadOnly="True"
                                        MaxHeight="80"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        Text="{x:Bind ErrorMessage}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
